{
  "name": "proj-eye",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-tauri-windows.ps1",
    "tauri:info:windows": "powershell -ExecutionPolicy Bypass -Command \"& { $tauriArgs = @('info'); .\\scripts\\run-tauri-windows.ps1 @tauriArgs }\"",
    "tauri:dev:windows": "powershell -ExecutionPolicy Bypass -Command \"& { $tauriArgs = @('dev'); .\\scripts\\run-tauri-windows.ps1 @tauriArgs }\"",
    "tauri:build:windows": "powershell -ExecutionPolicy Bypass -Command \"& { $tauriArgs = @('build', '--debug', '--no-bundle'); .\\scripts\\run-tauri-windows.ps1 @tauriArgs }\"",
    "cargo:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-cargo-windows.ps1",
    "cargo:check:windows": "powershell -ExecutionPolicy Bypass -Command \"& { $cargoArgs = @('check'); .\\scripts\\run-cargo-windows.ps1 @cargoArgs }\"",
    "cargo:clippy:windows": "powershell -ExecutionPolicy Bypass -Command \"& { $cargoArgs = @('clippy', '--', '-D', 'warnings'); .\\scripts\\run-cargo-windows.ps1 @cargoArgs }\""
  },
  "dependencies": {
    "zustand": "^5.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.1.4",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "@tauri-apps/cli": "^2"
  }
}
